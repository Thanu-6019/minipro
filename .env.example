# MedTrack AI - Environment Variables

Copy this file to `.env` for development or `.env.production` for production builds.

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Service Integrations
# These should be set as Supabase Edge Function secrets in production
OPENOCR_API_KEY=your_ocr_api_key_for_openocr
GROK_API_KEY=your_grok_api_key_for_grok_beta
OPENFDA_API_KEY=your_openfda_api_key_for_fda
